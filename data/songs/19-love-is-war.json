{
  "id": "19-love-is-war",
  "title": "恋は戦争",
  "artist": "supercell",
  "mode": "timed",
  "neteaseId": 22677561,
  "lines": [
    {
      "t": 11.73,
      "ja": "もう行き場がないわ",
      "zh": "已经无处可去"
    },
    {
      "t": 16.3,
      "ja": "この恋の熱量",
      "zh": "这份爱的热量"
    },
    {
      "t": 55.34,
      "ja": "灰色の雲",
      "zh": "灰色的云"
    },
    {
      "t": 59.36,
      "ja": "モノクロの喧騒",
      "zh": "单色调的喧噪"
    },
    {
      "t": 65.52,
      "ja": "日差しはかげり",
      "zh": "阳光照射成阴影"
    },
    {
      "t": 69.37,
      "ja": "夕暮れは色を変えていく",
      "zh": "日落会改变色彩"
    },
    {
      "t": 77.55,
      "ja": "世界がにじんで",
      "zh": "即使世界沉沦"
    },
    {
      "t": 81.71,
      "ja": "それでも好きでいられるかなんて",
      "zh": "喜欢你的心情依旧存在"
    },
    {
      "t": 87.39,
      "ja": "わかってる",
      "zh": "明明知道"
    },
    {
      "t": 89.9,
      "ja": "けどどうすればいいの",
      "zh": "但是该怎么做才好"
    },
    {
      "t": 93.19,
      "ja": "どうしたら どうすれば",
      "zh": "该怎么办 该怎么做"
    },
    {
      "t": 99.3,
      "ja": "バカだな… わたし",
      "zh": "真是笨啊… 我"
    },
    {
      "t": 101.21,
      "ja": "始めるのよ これは戦争",
      "zh": "开始了唷 这是战争"
    },
    {
      "t": 107.67,
      "ja": "嬉しそうなキミをみるなんて！",
      "zh": "看着似乎一脸欣喜的你！"
    },
    {
      "t": 113.23,
      "ja": "切なる恋 それは罪",
      "zh": "无奈的恋情 那就是罪"
    },
    {
      "t": 118.71,
      "ja": "見せてあげる わたしの想いを",
      "zh": "让你瞧分明 我的爱恋"
    },
    {
      "t": 134.86,
      "ja": "叫んでみた",
      "zh": "拿来试着吶喊的"
    },
    {
      "t": 138.94,
      "ja": "メガホンは壊れてたの",
      "zh": "扩音器坏掉了"
    },
    {
      "t": 145.14,
      "ja": "どれだけ背伸びしたって",
      "zh": "无论再怎样将背挺直"
    },
    {
      "t": 150.27,
      "ja": "君の視界に入らない",
      "zh": "依然无法进入你的视线"
    },
    {
      "t": 156.15,
      "ja": "嗚呼、いつの間にか晴れた空",
      "zh": "啊~ 天空是何时放晴的呢"
    },
    {
      "t": 165.3,
      "ja": "全然似合わない",
      "zh": "完全(与心情)不相符"
    },
    {
      "t": 167.7,
      "ja": "気持ちが抑えられなくて",
      "zh": "心情已经无法再压抑"
    },
    {
      "t": 172.56,
      "ja": "どうしたら どうすれば",
      "zh": "该怎么办 要怎么做"
    },
    {
      "t": 177.72,
      "ja": "泣いてなんか ないんだからね",
      "zh": "我要哭了吗 才没有那回事呢"
    },
    {
      "t": 185.0,
      "ja": "大好き",
      "zh": "最喜欢你了"
    },
    {
      "t": 186.32,
      "ja": "たたかうのよ ハートを撃て",
      "zh": "我要战斗唷 攻击你的心"
    },
    {
      "t": 192.7,
      "ja": "手段なんて選んでられない",
      "zh": "已经无法选择手段"
    },
    {
      "t": 197.96,
      "ja": "スカートひらり見せ付けるのよ",
      "zh": "让你瞧见我飞扬的裙摆"
    },
    {
      "t": 203.73,
      "ja": "君の視線奪ってみせるの",
      "zh": "将你的视线攻占给你看"
    },
    {
      "t": 211.69,
      "ja": "迎撃用意",
      "zh": "准备迎击"
    },
    {
      "t": 214.72,
      "ja": "戦況は未だ不利なのです",
      "zh": "战况仍旧不利"
    },
    {
      "t": 220.53,
      "ja": "恋は盲目",
      "zh": "恋爱是盲目的"
    },
    {
      "t": 225.69,
      "ja": "君の口づけで目が覚めるの！",
      "zh": "用你的吻让我清醒！"
    }
  ]
}