{
  "id": "17-caged-flower",
  "title": "囚われのマリオネット",
  "artist": "KAITO",
  "mode": "timed",
  "neteaseId": 2019338676,
  "lines": [
    {
      "t": 14.92,
      "ja": "青く澄んだ雨の病",
      "zh": "蓝色清澈的雨季的忧郁"
    },
    {
      "t": 18.25,
      "ja": "一人きりの呼吸は徒然",
      "zh": "孤独一人的呼吸是徒然"
    },
    {
      "t": 22.08,
      "ja": "痛む心に滲む鋼鉄の愛があった",
      "zh": "在疼痛的心中渗透着钢铁般坚实的爱"
    },
    {
      "t": 28.63,
      "ja": "触れたならば消えてしまう",
      "zh": "只要一触碰 就会消失"
    },
    {
      "t": 32.05,
      "ja": "微かに灯る炎のように",
      "zh": "像微亮的火苗一样"
    },
    {
      "t": 35.87,
      "ja": "全てを知らないままでいたいと君は言う",
      "zh": "你说你想就这样无知无觉"
    },
    {
      "t": 42.02,
      "ja": "透けた白い首筋に",
      "zh": "雪白透亮的脖颈上"
    },
    {
      "t": 46.37,
      "ja": "控えめに下がるGarnet",
      "zh": "稍稍滑落下来的Garnet"
    },
    {
      "t": 49.74,
      "ja": "閉じた目蓋に艶めくアイシャドウ",
      "zh": "在紧闭的眼睑上涂上艳丽的眼影"
    },
    {
      "t": 55.37,
      "ja": "羽のようにふわりと舞う体が",
      "zh": "像羽毛一样轻盈飞舞的身体"
    },
    {
      "t": 60.93,
      "ja": "時に震えて凍えて",
      "zh": "时而颤抖时而僵硬"
    },
    {
      "t": 65.3,
      "ja": "溢れた涙は冷たい",
      "zh": "溢出的泪水冰凉透骨"
    },
    {
      "t": 69.48,
      "ja": "甘い想いと憂いの恋は",
      "zh": "甜蜜的记忆和忧伤的恋爱"
    },
    {
      "t": 72.67,
      "ja": "幻のようで",
      "zh": "就像一场幻觉"
    },
    {
      "t": 75.7,
      "ja": "「どこにも行かないで」",
      "zh": "「哪儿也别去」"
    },
    {
      "t": 77.98,
      "ja": "なんて言葉すり抜けてく",
      "zh": "用诸如此类的话糊弄过去"
    },
    {
      "t": 81.1,
      "ja": "身勝手な夢",
      "zh": "自私的梦"
    },
    {
      "t": 83.1,
      "ja": "歪んだ瞳の奥見せた赤い光が",
      "zh": "在扭曲的瞳孔深处散发的红色光芒"
    },
    {
      "t": 89.5,
      "ja": "記憶の深くに巣食って",
      "zh": "盘踞在记忆深处"
    },
    {
      "t": 92.51,
      "ja": "煌めいては僕を突き放す",
      "zh": "闪耀着将我推开"
    },
    {
      "t": 111.37,
      "ja": "挽歌の海沈んだなら",
      "zh": "挽歌之海如若沉没"
    },
    {
      "t": 114.91,
      "ja": "静寂の悲愴を愛せただろう",
      "zh": "会爱上寂静的悲怆吧"
    },
    {
      "t": 118.8,
      "ja": "そんな話ばかりを僕らは好んでた",
      "zh": "我们只喜欢这样的故事"
    },
    {
      "t": 124.65,
      "ja": "夜空の星々さえ",
      "zh": "即便是夜空中的群星"
    },
    {
      "t": 129.15,
      "ja": "君に嫉妬するだろう",
      "zh": "都会嫉妒你吧"
    },
    {
      "t": 132.63,
      "ja": "遣り切れずため息をつくだろう",
      "zh": "会忍不住叹息吧"
    },
    {
      "t": 138.58,
      "ja": "瞳は僕を捉え",
      "zh": "你的眼睛捕捉到了我"
    },
    {
      "t": 142.97,
      "ja": "確かにそこにいるのに",
      "zh": "我明明就在那里"
    },
    {
      "t": 146.22,
      "ja": "映すのに",
      "zh": "映照在你的瞳孔里"
    },
    {
      "t": 148.29,
      "ja": "どこか虚ろに空を見る",
      "zh": "你却茫然地看着天空"
    },
    {
      "t": 152.14,
      "ja": "少しだけ絡めた指先",
      "zh": "微微缠绕的指尖"
    },
    {
      "t": 155.5,
      "ja": "酷く冷えていた",
      "zh": "冷到极致"
    },
    {
      "t": 158.53,
      "ja": "「ここが苦しいの」と笑った君は",
      "zh": "「这里太痛苦了」你笑着说"
    },
    {
      "t": 162.38,
      "ja": "数秒で手を離してしまう",
      "zh": "几秒后便松开了手"
    },
    {
      "t": 165.93,
      "ja": "伝えたい言葉は鋭利",
      "zh": "你说的话很尖锐"
    },
    {
      "t": 169.33,
      "ja": "それでも僕は",
      "zh": "即便如此我还是"
    },
    {
      "t": 172.31,
      "ja": "こんな人間だ",
      "zh": "这样的人啊"
    },
    {
      "t": 174.12,
      "ja": "証明をここに残す",
      "zh": "把证据留在这里"
    },
    {
      "t": 177.22,
      "ja": "「愛している、君だけを。」",
      "zh": "「我爱你、只有你。」"
    },
    {
      "t": 183.32,
      "ja": "深い眠りの奥いつか",
      "zh": "不知何时在沉睡中"
    },
    {
      "t": 186.59,
      "ja": "鼓動を確かめて",
      "zh": "察觉到心跳的声音"
    },
    {
      "t": 189.66,
      "ja": "全て夢だった",
      "zh": "才恍然大悟一切都是梦"
    },
    {
      "t": 191.46,
      "ja": "そして混沌は",
      "zh": "然后于混沌中"
    },
    {
      "t": 193.44,
      "ja": "また花開く、と歩き出す",
      "zh": "又见花开、迈步向前"
    },
    {
      "t": 197.06,
      "ja": "眩んだ視界の先十のうち",
      "zh": "在即将淡出晕眩的视野尽头"
    },
    {
      "t": 200.45,
      "ja": "君はもう遠く",
      "zh": "你已经走远"
    },
    {
      "t": 203.49,
      "ja": "薄い透明のベールをひらり纏い",
      "zh": "轻轻揭开一层薄薄的透明面纱"
    },
    {
      "t": 209.27,
      "ja": "闇を飾っていく",
      "zh": "装点着黑夜"
    }
  ]
}