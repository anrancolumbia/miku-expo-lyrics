      "t": 12.33,
      "ja": "I will never die",
      "zh": "I will never die"
    },
    {
      "t": 34.73,
      "ja": "夢中で走ったこの道の途中で",
      "zh": "忘我地奔跑在这条道路上"
    },
    {
      "t": 44.69,
      "ja": "何度も何度も躓いて転んで",
      "zh": "无数次跌跌撞撞"
    },
    {
      "t": 54.83,
      "ja": "描いた未来が",
      "zh": "我心向往的未来"
    },
    {
      "t": 57.68,
      "ja": "見えなくなったって",
      "zh": "却愈发遥不可及"
    },
    {
      "t": 60.82,
      "ja": "諦めたく無かった",
      "zh": "我依然未曾想过放弃"
    },
    {
